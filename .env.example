# ==============================
# .env.example – 환경변수 예시
# ==============================

# PostgreSQL 접속 정보
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5432/document_db

# 앱 설정
APP_NAME=Document Analyzer
UPLOAD_DIR=./data/uploads
WORK_DIR=./data/work
OCR_OUTPUT_DIR=./data/ocr_output

# Ollama 설정
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SEC=300
